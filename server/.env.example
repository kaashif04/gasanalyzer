# ── Biogas Monitor backend configuration ───────────────────────────────
# Copy this file to ".env" and fill in your values. NEVER commit the real .env.

# The Google Sheet ID (the long string in the sheet URL between /d/ and /edit).
SHEET_ID=

# A Google Cloud API key with the "Google Sheets API" enabled (read-only).
# The sheet must be shared as "Anyone with the link — Viewer", or published.
SHEETS_API_KEY=

# The tab/range to read. Defaults to the "Data" tab if unset.
SHEET_RANGE=Data

# Minutes EAST of UTC that the sheet's timestamp column is written in (the
# spreadsheet/Apps Script timezone, i.e. wherever the ESP32 actually is —
# NOT the timezone of whatever machine runs this backend). Default 480 =
# UTC+8. Get this wrong and every row's timestamp silently shifts by the
# difference, which breaks staleness detection and history range filtering.
SHEET_TZ_OFFSET_MIN=480

# How often to poll the sheet, in milliseconds (default 30000 = 30s).
POLL_INTERVAL_MS=30000

# Port the API server listens on.
PORT=4000

# Set to "true" to run with synthetic data instead of a real sheet.
# Useful for local development / demos when you don't have credentials yet.
# If SHEET_ID or SHEETS_API_KEY is missing, mock mode turns on automatically.
USE_MOCK=false
